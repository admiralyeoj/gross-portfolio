{
  "name": "admiralyeoj/gross-portfolio",
  "type": "project",
  "license": "MIT",
  "description": "WordPress boilerplate with Composer, easier configuration, and an improved folder structure",
  "homepage": "https://www.grossportfolio",
  "authors": [
    {
      "name": "Joey Gross",
      "homepage": "https://github.com/admiralyeoj"
    }
  ],
  "keywords": [
    "bedrock", "composer", "roots", "wordpress", "wp", "wp-config", "portfolio"
  ],
  "repositories": [
    {
      "type": "composer",
      "url": "https://wpackagist.org",
      "only": ["wpackagist-plugin/*", "wpackagist-theme/*"]
    },
    {
      "type": "package",
      "package": {
        "name": "advanced-custom-fields/advanced-custom-fields-pro",
        "version": "5.12.2",
        "type": "wordpress-plugin",
        "dist": {
          "type": "zip",
          "url": "https://connect.advancedcustomfields.com/index.php?a=download&p=pro&k={%ACF_PRO_KEY}&t={%version}"
        },
        "require": {
          "ffraenz/private-composer-installer": "^5.0"
        }
      }
    }
  ],
  "require": {
    "php": ">=7.4",
    "vlucas/phpdotenv": "^5.4",
    "oscarotero/env": "^2.1",
    "wp-cli/wp-cli" : "2.6.0",

    "roots/bedrock-autoloader": "^1.0",
    "roots/bedrock-disallow-indexing": "^2.0",
    "roots/wordpress": "5.9.3",
    "roots/wp-config": "1.0.0",
    "roots/wp-password-bcrypt": "1.1.0",

    "humanmade/s3-uploads": "3.0.4",
		"wpackagist-plugin/redis-cache": "1.3.5",
		"predis/predis": "1.1.1",
    "wpackagist-plugin/wordpress-seo":"18.5.1",
		"wpackagist-plugin/autoptimize":"3.0.2",
    "wpackagist-plugin/cloudflare":"4.8.3",
    "wpackagist-plugin/wordfence": "7.5.9",
    "wpackagist-plugin/wp-mail-smtp":"3.3.0",
    
		"advanced-custom-fields/advanced-custom-fields-pro": "^5.0.0"
  },
  "require-dev": {
    "heroku/heroku-buildpack-php": "*",
    "squizlabs/php_codesniffer": "^3.6.2",
    "roave/security-advisories": "dev-latest"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "extra": {
    "wordpress-install-dir": "web/wp",
    "installer-paths": {
      "web/app/mu-plugins/{$name}/": [
        "type:wordpress-muplugin"
      ],
      "web/app/plugins/{$name}/": [
        "type:wordpress-plugin",
        "wpackagist-plugin/wordfence",
				"wpackagist-plugin/nginx-helper",
				"humanmade/s3-uploads",
				"wpackagist-plugin/wordpress-seo",
				"wpackagist-plugin/better-search-replace",
				"wpackagist-plugin/cloudflare",
        "wpackagist-plugin/wp-mail-smtp"
      ],
      "web/app/themes/{$name}/": [
        "type:wordpress-theme"
      ]
    },
    "dropin-paths": {
			"web/app": [
			"package:wpackagist-plugin/redis-cache:includes/object-cache.php"
			]
		}
  },
  "scripts": {
    "scripts": {
      "wordpress-setup-core-install-prompt": "wp core install --prompt",
      "wordpress-setup-core-install": "wp core install --skip-email",
      "wordpress-setup-clear-home": "wp option delete home || true",
      "wordpress-setup-configure-s3": "echo '{\"domain\":\"path\",\"copy-to-s3\":\"1\",\"serve-from-s3\":\"1\",\"ssl\":\"request\"}' | wp option add tantan_wordpress_s3 --format=json",
      "wordpress-setup-enable-plugins": "wp plugin activate amazon-web-services amazon-s3-and-cloudfront",
      "wordpress-setup-permalink-structure": "wp rewrite structure '/%postname%/' || true",
      "wordpress-setup": [
        "@wordpress-setup-core-install-prompt",
        "@wordpress-setup-finalize"
      ],
      "wordpress-setup-finalize": [
        "@wordpress-setup-clear-home",
        "@wordpress-setup-configure-s3",
        "@wordpress-setup-enable-plugins",
        "@wordpress-setup-permalink-structure"
      ],
      "wordpress-setup-demo-theme": "wp theme activate portfolio",
      "wordpress-setup-welcome-post": [
        "echo 'It works! | wp post update 1 - --post_title=\"Welcome to WordPress on Heroku\""
      ]
    }
  },
  "env": {
    "WORDPRESS_ADMIN_EMAIL": {
      "description": "WordPress Administrator E-Mail"
    },
    "WORDPRESS_ADMIN_USER": {
      "description": "WordPress Administrator Username",
      "value": "admin"
    },
    "WORDPRESS_ADMIN_PASSWORD": {
      "description": "WordPress Administrator Password"
    },
    "WORDPRESS_AUTH_KEY": {
      "generator": "secret",
      "description": "security token generated for WordPress"
    },
    "WORDPRESS_SECURE_AUTH_KEY": {
      "generator": "secret",
      "description": "security token generated for WordPress"
    },
    "WORDPRESS_LOGGED_IN_KEY": {
      "generator": "secret",
      "description": "security token generated for WordPress"
    },
    "WORDPRESS_NONCE_KEY": {
      "generator": "secret",
      "description": "security token generated for WordPress"
    },
    "WORDPRESS_AUTH_SALT": {
      "generator": "secret",
      "description": "security token generated for WordPress"
    },
    "WORDPRESS_SECURE_AUTH_SALT": {
      "generator": "secret",
      "description": "security token generated for WordPress"
    },
    "WORDPRESS_LOGGED_IN_SALT": {
      "generator": "secret",
      "description": "security token generated for WordPress"
    },
    "WORDPRESS_NONCE_SALT": {
      "generator": "secret",
      "description": "security token generated for WordPress"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "allow-plugins": {
      "composer/installers": true,
      "wp-cli/autoload-splitter": true,
      "ffraenz/private-composer-installer": true,
      "johnpbloch/wordpress-core-installer": true,
      "roots/wordpress-core-installer": true
    }
  }
}
