{
  "name": "admiralyeoj/gross-portfolio",
  "type": "project",
  "license": "MIT",
  "description": "WordPress boilerplate with Composer, easier configuration, and an improved folder structure",
  "homepage": "https://www.grossportfolio",
  "authors": [
    {
      "name": "Joey Gross",
      "homepage": "https://github.com/admiralyeoj"
    }
  ],
  "keywords": [
    "bedrock", "composer", "roots", "wordpress", "wp", "wp-config", "portfolio"
  ],
  "repositories": [
    {
      "type": "composer",
      "url": "https://wpackagist.org",
      "only": ["wpackagist-plugin/*", "wpackagist-theme/*"]
    },
    {
      "type": "package",
      "package": {
        "name": "advanced-custom-fields/advanced-custom-fields-pro",
        "version": "5.12.2",
        "type": "wordpress-plugin",
        "dist": {
          "type": "zip",
          "url": "https://connect.advancedcustomfields.com/index.php?a=download&p=pro&k={%ACF_PRO_KEY}&t={%version}"
        },
        "require": {
          "composer/installers": "^2.1.1",
          "ffraenz/private-composer-installer": "^5.0.1"
        }
      }
    }
  ],
  "require": {
    "php": ">=7.4",
    "vlucas/phpdotenv": "^5.4",
    "oscarotero/env": "^2.1",
    "wp-cli/wp-cli" : "2.6.0",

    "roots/bedrock-autoloader": "^1.0",
    "roots/bedrock-disallow-indexing": "^2.0",
    "roots/wordpress": "5.9.3",
    "roots/wp-config": "1.0.0",
    "roots/wp-password-bcrypt": "1.1.0",

    "humanmade/s3-uploads": "3.0.4",
		"wpackagist-plugin/redis-cache": "1.3.5",
		"predis/predis": "1.1.1",
    "wpackagist-plugin/wordpress-seo":"18.5.1",
		"wpackagist-plugin/autoptimize":"3.0.2",
    "wpackagist-plugin/cloudflare":"4.8.3",
		"wpackagist-plugin/post-smtp":"2.0.25",
    "wpackagist-plugin/wordfence": "7.5.9",
		"advanced-custom-fields/advanced-custom-fields-pro": "^5.0.0"
  },
  "require-dev": {
    "heroku/heroku-buildpack-php": "*",
    "squizlabs/php_codesniffer": "^3.6.2",
    "roave/security-advisories": "dev-latest"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "allow-plugins": {
      "composer/installers": true,
      "roots/wordpress-core-installer": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "extra": {
    "installer-paths": {
      "web/app/mu-plugins/{$name}/": [
        "type:wordpress-muplugin"
      ],
      "web/app/plugins/{$name}/": [
        "type:wordpress-plugin",
        "wpackagist-plugin/wordfence",
				"wpackagist-plugin/nginx-helper",
				"humanmade/s3-uploads",
				"wpackagist-plugin/wordpress-seo",
				"wpackagist-plugin/better-search-replace",
				"wpackagist-plugin/cloudflare",
				"wpackagist-plugin/post-smtp"
      ],
      "web/app/themes/{$name}/": [
        "type:wordpress-theme"
      ]
    },
    "wordpress-install-dir": "web/wp"
  },
  "scripts": {
    "post-root-package-install": [
      "php -r \"copy('.env.example', '.env');\""
    ],
    "test": [
      "phpcs"
    ]
  }
}
