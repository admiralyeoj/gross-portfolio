{
  "name": "Heroku Base Setup",
  "description": "WordPress boilerplate with Composer, easier configuration, and an improved folder structure",
  "keywords": [
    "bedrock", "composer", "roots", "wordpress", "wp", "wp-config"
  ],
  "website": "https://www.grossportfolio.com/",
  "repository": "https://github.com/admiralyeoj/gross-portolio",
  "success_url": "/wp/wp-admin",
  "stack": "heroku-20",
  "scripts": {
    "postdeploy": "composer wordpress-setup-core-install -- --title='Heroku Base Setup' --admin_user=\"$WORDPRESS_ADMIN_USER\" --admin_password=\"$WORDPRESS_ADMIN_PASSWORD\" --admin_email=\"$WORDPRESS_ADMIN_EMAIL\" --url='http://example.herokuapp.com/' && composer wordpress-setup-finalize && composer wordpress-setup-demo-theme && composer wordpress-setup-welcome-post"
  },
  "env": {
    "WORDPRESS_ADMIN_EMAIL": {
      "description": "WordPress Administrator E-Mail"
    },
    "WORDPRESS_ADMIN_USER": {
      "description": "WordPress Administrator Username",
      "value": "admin"
    },
    "WORDPRESS_ADMIN_PASSWORD": {
      "description": "WordPress Administrator Password"
    },
    "WORDPRESS_AUTH_KEY": {
      "generator": "secret",
      "description": "security token generated for WordPress"
    },
    "WORDPRESS_SECURE_AUTH_KEY": {
      "generator": "secret",
      "description": "security token generated for WordPress"
    },
    "WORDPRESS_LOGGED_IN_KEY": {
      "generator": "secret",
      "description": "security token generated for WordPress"
    },
    "WORDPRESS_NONCE_KEY": {
      "generator": "secret",
      "description": "security token generated for WordPress"
    },
    "WORDPRESS_AUTH_SALT": {
      "generator": "secret",
      "description": "security token generated for WordPress"
    },
    "WORDPRESS_SECURE_AUTH_SALT": {
      "generator": "secret",
      "description": "security token generated for WordPress"
    },
    "WORDPRESS_LOGGED_IN_SALT": {
      "generator": "secret",
      "description": "security token generated for WordPress"
    },
    "WORDPRESS_NONCE_SALT": {
      "generator": "secret",
      "description": "security token generated for WordPress"
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "free"
    }
  },
  "addons": [
    {
      "plan": "jawsdb-maria:kitefin"
    },
    {
      "plan": "sendgrid:starter"
    },
    {
      "plan": "heroku-redis:hobby-dev"
    },
    {
      "plan": "papertrail:choklad"
    },
    {
      "plan": "autobus:trip"
    }
  ],
  "buildpacks": [
    {
      "url": "https://github.com/heroku/heroku-buildpack-php"
    }
  ]
}